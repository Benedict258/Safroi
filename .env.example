# ============================================
# Safroi - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.

# Required: MongoDB connection string
# MongoDB Atlas provides this for free (https://mongodb.com/atlas)
# Format: mongodb+srv://user:password@cluster.xxxxx.mongodb.net/safroi
MONGODB_URI=

# Required: Groq API key for AI analysis
# Get one at https://console.groq.com/keys
GROQ_API_KEY=

# Optional: Groq model (default shown)
GROQ_MODEL=gpt-oss-120b

# Optional: Serper.dev API key for Google Search fallback
# Get one at https://serper.dev/
SERPER_API_KEY=

# Server port (default: 3000)
PORT=3000

# Application URL (used for Chrome extension config)
APP_URL=http://localhost:3000

# Vite base path (use only when deploying behind a reverse proxy)
# Example: VITE_BASE=/app/
VITE_BASE=/

# Disable HMR (set to 'true' in CI or when file watching causes issues)
DISABLE_HMR=false
