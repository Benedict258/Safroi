# GROQ_API_KEY: Required for Groq AI API calls.
# Users configure this via the Secrets panel in the AI Studio UI.
GROQ_API_KEY=
# GROQ_MODEL: The model to use for analysis (e.g., llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# SERPER_API_KEY: Optional search API key for "Google Search" abilities
# Get one at serper.dev
SERPER_API_KEY=

APP_URL=
