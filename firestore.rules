rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && incoming().uid == userId
        && incoming().email == request.auth.token.email
        && incoming().createdAt == request.time
        && incoming().keys().hasAll(['uid', 'email', 'createdAt'])
        && incoming().keys().size() <= 10;
      allow update: if isOwner(userId)
        && incoming().uid == userId
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']);
    }

    // Analysis History Rules
    match /users/{userId}/history/{analysisId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId);
      allow create: if isOwner(userId)
        && isValidId(analysisId)
        && incoming().userId == userId
        && incoming().timestamp == request.time
        && incoming().risk_score is number
        && incoming().risk_score >= 0 && incoming().risk_score <= 10
        && incoming().type in ['website', 'contract']
        && incoming().keys().hasAll(['userId', 'type', 'value', 'risk_score', 'summary', 'risks', 'timestamp'])
        && incoming().keys().size() <= 12;
      allow delete: if isOwner(userId);
    }
  }
}
